#!/bin/bash
# icon-asm — Tiny-ICON compiler wrapper
# Usage: icon-asm <file.icn>
# Compiles file.icn via icon_driver → NASM → gcc, then runs it.
# Output goes to stdout. Exit code reflects program exit.
#
# Mirrors snobol4-asm interface: accepts one .icn file, prints output.

set -e
REPO="$(cd "$(dirname "$0")" && pwd)"
DRIVER="${REPO}/icon_driver"

if [[ ! -x "$DRIVER" ]]; then
    # Build driver if not already built
    cc -std=c11 \
        -I"${REPO}/src/frontend/icon" \
        "${REPO}/src/frontend/icon/icon_lex.c" \
        "${REPO}/src/frontend/icon/icon_ast.c" \
        "${REPO}/src/frontend/icon/icon_parse.c" \
        "${REPO}/src/frontend/icon/icon_emit.c" \
        "${REPO}/src/frontend/icon/icon_driver.c" \
        -o "$DRIVER"
fi

ICN="${1:-}"
if [[ -z "$ICN" ]]; then
    echo "usage: icon-asm <file.icn>" >&2
    exit 1
fi

BASE=$(mktemp /tmp/icon_XXXXXX)
ASM="${BASE}.asm"
OBJ="${BASE}.o"
BIN="${BASE}.bin"

"$DRIVER" -o "$ASM" "$ICN"
nasm -f elf64 "$ASM" -o "$OBJ"
gcc -nostdlib -no-pie -Wl,--no-warn-execstack \
    "$OBJ" \
    "${REPO}/src/frontend/icon/icon_runtime.c" \
    -o "$BIN"

"$BIN"
STATUS=$?
rm -f "$ASM" "$OBJ" "$BIN"
exit $STATUS
