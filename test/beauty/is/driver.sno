*  driver.sno — test driver for is.sno
*  Oracle: snobol4 -f -P256k -I$INC driver.sno
*  Run via: bash test/beauty/run_beauty_subsystem.sh is
*  All 3 participants (CSNOBOL4, SPITBOL, ASM) must produce identical output.
*  Strategy: IsSnobol4 XOR IsSpitbol — exactly one succeeds on any runtime.
*  We test that property (exactly one fires) rather than which one.
-INCLUDE 'global.sno'
-INCLUDE 'is.sno'

        &STLIMIT = 1000000

*  Exactly one of IsSnobol4/IsSpitbol must succeed
        sno4_ = 0
        spl_  = 0
        IsSnobol4()   :S(mark_sno4)
        :(check_spl)
mark_sno4
        sno4_ = 1
check_spl
        IsSpitbol()   :S(mark_spl)
        :(xor_check)
mark_spl
        spl_ = 1
xor_check
*  XOR: exactly one must be 1
        IDENT(sno4_, 1) IDENT(spl_, 1)   :S(both_fail)
        IDENT(sno4_, 0) IDENT(spl_, 0)   :S(neither_fail)
        OUTPUT = 'PASS: exactly one of IsSnobol4/IsSpitbol succeeded'   :(done)
both_fail
        OUTPUT = 'FAIL: both IsSnobol4 and IsSpitbol succeeded'   :(done)
neither_fail
        OUTPUT = 'FAIL: neither IsSnobol4 nor IsSpitbol succeeded'
done
END
