* coverage_sno_nodes.sno — exercises every SNOBOL4 IR node kind
* One touch per node: AST_QLIT AST_ILIT AST_FLIT AST_VART AST_KW AST_NULV
*   AST_ADD AST_SUB AST_MPY AST_DIV AST_ASGN AST_EXPOP
*   AST_CONCAT AST_SEQ AST_OR AST_NAM AST_DOL AST_ATP AST_ARB AST_ARBNO AST_STAR AST_INDR
*   AST_FNC AST_IDX AST_NULV AST_OPSYN AST_MNS AST_PLUS

* AST_QLIT — string literal
        OUTPUT = 'hello'

* AST_ILIT — integer literal
        OUTPUT = 42

* AST_FLIT — float literal
        X = 1.5
        OUTPUT = X

* AST_VART — variable reference
        A = 'world'
        OUTPUT = A

* AST_KW — keyword reference
        OUTPUT = &ALPHABET

* AST_ADD AST_SUB AST_MPY AST_DIV — arithmetic
        OUTPUT = 3 + 4
        OUTPUT = 10 - 3
        OUTPUT = 3 * 4
        OUTPUT = 10 / 2

* AST_MNS — unary minus
        N = -5
        OUTPUT = N

* AST_EXPOP — exponentiation
        OUTPUT = 2 ** 8

* AST_CONCAT — value-context string concat
        OUTPUT = 'foo' 'bar'

* AST_ASGN — pattern = assignment capture
        S = 'hello world'
        S ('hello' = CAPT)
        OUTPUT = CAPT

* AST_SEQ — pattern sequence (CAT)
        S2 = 'abcd'
        S2 'ab' 'cd'
        OUTPUT = 'seq ok'

* AST_OR — pattern alternation
        S3 = 'cat'
        S3 ('dog' | 'cat')
        OUTPUT = 'alt ok'

* AST_NAM — named capture (.)
        S4 = 'hello'
        S4 LEN(3) . PART
        OUTPUT = PART

* AST_DOL — replacement capture ($)
        S5 = 'hello world'
        S5 'world' $ TRAIL
        OUTPUT = TRAIL

* AST_ATP — cursor capture (@)
        S6 = 'abcdef'
        S6 'abc' @ POS1
        OUTPUT = POS1

* AST_ARB — ARB builtin
        S7 = 'xaby'
        S7 ARB 'b'
        OUTPUT = 'arb ok'

* AST_ARBNO — ARBNO()
        S8 = 'aaab'
        S8 ARBNO('a') 'b'
        OUTPUT = 'arbno ok'

* AST_STAR — deferred pattern (*VAR)
        PAT = LEN(2)
        S9 = 'abcd'
        S9 *PAT
        OUTPUT = 'star ok'

* AST_INDR — indirect reference ($VAR as pattern)
        VNAME = 'A'
        OUTPUT = $VNAME

* AST_FNC — function call
        OUTPUT = SIZE('hello')

* AST_IDX — array indexing
        T = TABLE()
        T<'key'> = 'val'
        OUTPUT = T<'key'>

* AST_NULV — null value (uninitialized)
        OUTPUT = IDENT(UNDEF,)  :S(NULLOK)
        OUTPUT = 'not null'     :(DONE)
NULLOK  OUTPUT = 'null ok'
DONE

* AST_OPSYN — operator synonym
        OPSYN('MYSIZE','SIZE',1)
        OUTPUT = MYSIZE('hi')

END
