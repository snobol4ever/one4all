*  078 - GT numeric comparison
        GT(5, 3)                                                    :S(YES)F(NO)
YES     OUTPUT = '5 > 3'
        :(NEXT)
NO      OUTPUT = 'wrong'
NEXT    GT(3, 5)                                                    :S(YES2)F(NO2)
YES2    OUTPUT = 'wrong'
        :(END)
NO2     OUTPUT = '3 not > 5'
END
