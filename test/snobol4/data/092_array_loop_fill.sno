*  092 - Fill array in loop, read back
        A = ARRAY(5)
        I = 1
FILL    A<I> = I * I
        I = I + 1
        LE(I, 5)                                                    :S(FILL)
        I = 1
READ    OUTPUT = A<I>
        I = I + 1
        LE(I, 5)                                                    :S(READ)
END
