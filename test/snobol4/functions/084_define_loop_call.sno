*  084 - Function called in loop, concat results (from dotnet bump)
        DEFINE('bump(v)')                                           :(bumpend)
bump    bump = v + 1                                               :(RETURN)
bumpend
        S = ''
        J = 0
LOOP    S = S bump(2 * J)
        J = J + 1
        LT(J, 5)                                                    :S(LOOP)
        OUTPUT = S
END
