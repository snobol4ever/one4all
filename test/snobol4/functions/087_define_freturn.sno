*  087 - Function fails via FRETURN, calling code handles :F
        DEFINE('ispos(x)')                                          :(ispos_end)
ispos   GT(x, 0)                                                   :S(RETURN)F(FRETURN)
ispos_end
        ispos(5)                                                    :S(A)F(B)
A       OUTPUT = 'positive'
        :(NEXT)
B       OUTPUT = 'wrong'
NEXT    ispos(-3)                                                   :S(C)F(D)
C       OUTPUT = 'wrong'
        :(END)
D       OUTPUT = 'not positive'
END
