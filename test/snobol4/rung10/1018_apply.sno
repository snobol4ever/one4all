* 1018_apply.sno — APPLY: call a function given its name as a value
* Rung 10. 3 assertions.

*       apply a failing predicate — should fail
        apply(.eq, 1, 2)           :f(e001)
        output = 'FAIL 1018/001: apply(.eq,1,2) should fail' :(end)
e001

*       apply a passing predicate — should succeed
        apply(.eq, 1, 1)           :s(e002)
        output = 'FAIL 1018/002: apply(.eq,1,1) should succeed' :(end)
e002

*       apply a string-returning function
        differ(apply(.trim, 'abc   '), 'abc')                   :f(e003)
        output = 'FAIL 1018/003: apply(.trim,...)'     :(end)
e003

        output = 'PASS 1018_apply (3/3)'
end
