* 1013_func_nreturn.sno — NRETURN: return a name (lvalue) from a function
* Rung 10. 3 assertions.

        define('ref_a()')                              :(ref_a_end)
ref_a   ref_a = .a                                     :(nreturn)
ref_a_end

        a = 27

*       ref_a() returns the name .a — reading it gives a's value
        differ(ref_a(), 27)                            :f(e001)
        output = 'FAIL 1013/001: nreturn read gives value' :(end)
e001

*       assigning to ref_a() assigns into a; lvalue assign succeeds
        ref_a() = 26                                   :s(e002)
        output = 'FAIL 1013/002: nreturn lvalue assign failed' :(end)
e002

        differ(a, 26)                                  :f(e003)
        output = 'FAIL 1013/003: a updated via nreturn'   :(end)
e003

        output = 'PASS 1013_func_nreturn (3/3)'
end
