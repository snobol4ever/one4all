# Makefile — test/ss-monitor
# M-SS-MON-0 gate: `make` succeeds

CC      = gcc
CFLAGS  = -Wall -Wextra -std=c99 -g -O0
SILLY_SRC = $(wildcard ../../src/silly/*.c)
SILLY_INC = -I../../src/silly

# CSNOBOL4 source dir (from uploaded tarball)
CSN_DIR = /home/claude/work/snobol4-2.3.3
CSN_SRC = $(CSN_DIR)/snobol4-wrapped.c  # generated by wrap_snobol4.py

.PHONY: all ping clean csn sly

all: ping_test

# M-SS-MON-0: infrastructure compiles
ping_test: ping_test.c mon_hooks.c mon_hooks.h
	$(CC) $(CFLAGS) ping_test.c mon_hooks.c -o ping_test
	@echo "M-SS-MON-0: ping_test built ✓"

mon_hooks.o: mon_hooks.c mon_hooks.h
	$(CC) $(CFLAGS) -c mon_hooks.c -o mon_hooks.o

# M-SS-MON-2: CSNOBOL4 instrumented binary
# wrap_snobol4.py generates snobol4-wrapped.c from snobol4.c
csn-wrap:
	python3 wrap_snobol4.py $(CSN_DIR)/snobol4.c $(CSN_DIR)/snobol4-wrapped.c
	@echo "wrap_snobol4.py: generated snobol4-wrapped.c ✓"

snobol4-mon: csn-wrap mon_hooks.o
	$(CC) $(CFLAGS) $(CSN_DIR)/snobol4-wrapped.c mon_hooks.o \
	    -I$(CSN_DIR) -I. \
	    -ldl -lm -o /home/claude/work/snobol4-2.3.3/snobol4-mon
	@echo "M-SS-MON-2: snobol4-mon built ✓"

# M-SS-MON-3: Silly instrumented binary
# silly-mon: rebuild src/silly with MON hooks compiled in
silly-mon: mon_hooks.o
	$(CC) $(CFLAGS) $(SILLY_SRC) mon_hooks.c -lm \
	    $(SILLY_INC) -I. \
	    -DMON_ENABLED \
	    -o /tmp/silly-mon
	@echo "M-SS-MON-3: silly-mon built ✓"

# M-SS-MON-1: ping test
ping: ping_test
	chmod +x run_ss_monitor.sh
	./run_ss_monitor.sh --ping --timeout 5
	@echo "M-SS-MON-1: ping PASS ✓"

clean:
	rm -f ping_test mon_hooks.o
